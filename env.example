# ─── REQUIRED ─────────────────────────────────────────────────────────────────
CSFLOAT_API_KEY=your_csfloat_api_key_here

# ─── KNIFE FAMILIES ───────────────────────────────────────────────────────────
# Comma-separated substrings matched against market_hash_name (case-insensitive)
KNIFE_FAMILIES=Talon,Karambit,Butterfly

# ─── PRICE RANGE (USD) ────────────────────────────────────────────────────────
MIN_PRICE_USD=50
MAX_PRICE_USD=5000

# ─── PRICE SOURCE ─────────────────────────────────────────────────────────────
# Determines what price the CSFloat ask is compared against.
#
#   csfloat_base        → listing.reference.base_price from the CSFloat payload
#                         (no Steam calls — instant, zero rate-limit risk)
#                         spread = base_price − csfloat_ask
#
#   steam_max_buy_order → highest active Steam buy order (histogram API)
#                         spread = steam_buy_order − csfloat_ask
#                         Best for: "can I sell this immediately on Steam?"
#
#   steam_min_listing   → lowest active Steam listing (priceoverview API)
#                         spread = steam_min_listing − csfloat_ask
#                         Best for: "how does CSFloat compare to cheapest Steam ask?"
#
PRICE_SOURCE=csfloat_base

# ─── SCAN DEPTH ───────────────────────────────────────────────────────────────
# Pages fetched from CSFloat per scan (100 listings/page, max 10)
SCAN_PAGES=3

# Top N results shown / sent to Telegram
TOP_N=10

# Minimum spread ($USD) to include. 0 = show all (including negative spreads).
MIN_SPREAD_USD=0

# ─── POLLING ──────────────────────────────────────────────────────────────────
# 0 = run once and exit. >0 = repeat every N seconds.
# Recommended minimum when using Steam modes: 300 (5 min)
POLL_INTERVAL_SECONDS=0

# ─── STEAM SETTINGS (only used when PRICE_SOURCE != csfloat_base) ─────────────
# Delay between each Steam HTTP request (ms). Keep >= 1000 to avoid bans.
STEAM_REQUEST_DELAY_MS=1500

# How long to cache Steam prices (seconds). 600 = 10 min.
STEAM_CACHE_TTL_SECONDS=600

# ─── TELEGRAM (optional) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── DEBUG ────────────────────────────────────────────────────────────────────
DEBUG=false
